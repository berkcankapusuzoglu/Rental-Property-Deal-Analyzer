# AI Provider: "auto" (default), "ollama" (free/local), or "anthropic" (paid)
AI_PROVIDER=auto

# Anthropic API (paid) - get key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (free/local) - install from https://ollama.com, then: ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
